{
  "name": "mindforge-sdk",
  "version": "11.8.3",
  "description": "MindForge SDK — Programmatic API for embedding MindForge in tools",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "pretest": "npm run build",
    "test": "node tests/sdk.test.js && node tests/execute-command.test.js",
    "lint": "eslint .",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "mindforge",
    "agentic-framework",
    "claude",
    "sdk"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.19.43",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0"
  }
}
