{
  "name": "@mindforge/sdk",
  "version": "10.0.6",
  "description": "MindForge SDK \u2014 Programmatic API for embedding MindForge in tools",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist/", "README.md"],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "node tests/sdk.test.js",
    "lint": "eslint .",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "mindforge",
    "agentic-framework",
    "claude",
    "sdk"
  ],
  "license": "MIT",
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0"
  }
}
