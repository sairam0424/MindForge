{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/run-with-flags.js\" mindforge-check-update .agent/hooks/mindforge-check-update.js minimal,standard,strict"
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/run-with-flags.js\" mindforge-session-init .agent/hooks/mindforge-session-init_extended.js minimal,standard,strict"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/run-with-flags.js\" mindforge-context-monitor .agent/hooks/mindforge-context-monitor.js standard,strict",
            "timeout": 10000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/run-with-flags.js\" mindforge-prompt-guard .agent/hooks/mindforge-prompt-guard.js standard,strict",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/run-with-flags.js\" trust-gate bin/security/trust-gate-hook.js minimal,standard,strict",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/run-with-flags.js\" mindforge-block-no-verify .agent/hooks/mindforge-block-no-verify.js minimal,standard,strict",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
