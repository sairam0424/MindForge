      "trust_tier": 3,
      "decision_gate": "hitl",
      "resource_budget": "high",
      "required_skills": ["security-engineer"]
    },
    "AIEngineeringSwarm": {
      "leader": "ai-engineer",
      "members": ["prompt-engineer", "developer", "model-qa-specialist"],
