{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MindForge Hooks Configuration",
  "description": "Schema for MindForge settings.json hooks. Ported from ECC's Claude Code hooks schema, with the event-name enum EXTENDED to include the Gemini-mirror events (BeforeTool/AfterTool) used by .agent/settings.json, so a single schema lints BOTH .claude/settings.json and the .agent mirror.",
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "commandHookItem": {
      "type": "object",
      "required": [
        "type",
        "command"
      ],
      "properties": {
        "type": {
          "type": "string",
          "const": "command",
          "description": "Run a local command"
        },
        "command": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "$ref": "#/$defs/stringArray"
            }
          ]
        },
        "async": {
          "type": "boolean",
          "description": "Run hook asynchronously in background without blocking"
        },
        "timeout": {
          "type": "number",
          "minimum": 0,
          "description": "Timeout in milliseconds (Claude Code / MindForge convention)"
        }
      },
      "additionalProperties": true
    },
    "httpHookItem": {
      "type": "object",
      "required": [
        "type",
        "url"
      ],
      "properties": {
        "type": {
          "type": "string",
          "const": "http"
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "headers": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "allowedEnvVars": {
          "$ref": "#/$defs/stringArray"
        },
        "timeout": {
          "type": "number",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "promptHookItem": {
      "type": "object",
      "required": [
        "type",
        "prompt"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["prompt", "agent"]
        },
        "prompt": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "timeout": {
          "type": "number",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "hookItem": {
      "oneOf": [
        {
          "$ref": "#/$defs/commandHookItem"
        },
        {
          "$ref": "#/$defs/httpHookItem"
        },
        {
          "$ref": "#/$defs/promptHookItem"
        }
      ]
    },
    "matcherEntry": {
      "type": "object",
      "required": [
        "hooks"
      ],
      "properties": {
        "matcher": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "object"
            }
          ]
        },
        "hooks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/hookItem"
          }
        },
        "description": {
          "type": "string"
        }
      }
    }
  },
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "permissions": {
      "type": "object",
      "properties": {
        "deny": { "$ref": "#/$defs/stringArray" },
        "allow": { "type": "array", "items": { "type": "string" } },
        "ask": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "hooks": {
      "type": "object",
      "propertyNames": {
        "enum": [
          "SessionStart",
          "UserPromptSubmit",
          "PreToolUse",
          "PermissionRequest",
          "PostToolUse",
          "PostToolUseFailure",
          "Notification",
          "SubagentStart",
          "Stop",
          "SubagentStop",
          "PreCompact",
          "InstructionsLoaded",
          "TeammateIdle",
          "TaskCompleted",
          "ConfigChange",
          "WorktreeCreate",
          "WorktreeRemove",
          "SessionEnd",
          "BeforeTool",
          "AfterTool"
        ]
      },
      "additionalProperties": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/matcherEntry"
        }
      }
    }
  },
  "required": [
    "hooks"
  ],
  "additionalProperties": true
}
