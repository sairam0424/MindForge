{
  "permissions": {
    "deny": [
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(**/.env*)",
      "Write(~/.ssh/**)",
      "Write(~/.aws/**)",
      "Bash(curl * | bash)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(nc *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "node .agent/hooks/mindforge-context-monitor.js",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "Bash|Task",
        "hooks": [
          {
            "type": "command",
            "command": "node bin/hooks/instinct-capture-hook.js",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .agent/hooks/mindforge-prompt-guard.js",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node bin/security/trust-gate-hook.js",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "node .agent/hooks/mindforge-block-no-verify.js",
            "timeout": 5000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .agent/hooks/mindforge-session-init_extended.js"
          },
          {
            "type": "command",
            "command": "node .agent/hooks/mindforge-check-update.js"
          }
        ]
      }
    ]
  }
}
